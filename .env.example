# ─── DATABASE ────────────────────────────────────────────────
# Supabase PostgreSQL — pooled connection (for Prisma queries)
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI) → use port 6543
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — direct connection (for migrations)
# Get from: Supabase Dashboard → Settings → Database → Connection string (URI) → use port 5432
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── SITE URL ────────────────────────────────────────────────
# Public URL of the deployed site
# For local dev: http://localhost:3000
# For production: https://emmanails.ro
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── AUTH ────────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl"

# NextAuth URL — must match your site URL
# For local dev: http://localhost:3000
# For production: https://emmanails.ro
NEXTAUTH_URL="http://localhost:3000"

# ─── STRIPE ──────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Webhook Secret
# For local dev: use Stripe CLI → stripe listen --forward-to localhost:3000/api/webhook/stripe
# For production: create webhook at https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── ADMIN ───────────────────────────────────────────────────
# Password for admin panel at /admin
# Change this to something secure in production!
ADMIN_PASSWORD="emma2026"

# ─── EMAIL (Resend) ─────────────────────────────────────────
# Get from: https://resend.com/api-keys
# Free tier: 100 emails/day
RESEND_API_KEY="re_..."
