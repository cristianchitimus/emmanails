generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── PRODUCTS ──────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  price       Int         // price in bani (1 leu = 100 bani)
  salePrice   Int?        // sale price in bani, null if not on sale
  category    String      // "polygel" | "instrumente"
  subcategory String?     // "polygel-color", "polygel-reflective", etc.
  size        String?     // "30g", "60g", etc.
  inStock     Boolean     @default(true)
  stock       Int?        // null = unlimited, 0 = out of stock
  featured    Boolean     @default(false)
  imageUrl    String?
  images      String[]    // all product images
  colorHex    String?     // hex color for swatch heart preview
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── COURSES ───────────────────────────────────────────────

model Course {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  description      String?
  priceFrom        Int             // avans price in bani
  priceTo          Int             // full price in bani
  level            String?         // "incepator", "mediu", "avansat"
  duration         String?         // e.g. "3 zile", "5 zile"
  includes         String[]        // what's included
  curriculum       String[]        // course curriculum items
  dates            String[]        // legacy dates (kept for backward compat)
  hasAccreditation Boolean         @default(false)
  featured         Boolean         @default(false)
  imageUrl         String?
  images           String[]        // all course gallery images
  sessions         CourseSession[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model CourseSession {
  id          String             @id @default(cuid())
  courseId    String
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  dateLabel   String             // "19-23 Ianuarie 2026"
  maxSpots    Int                @default(10)
  active      Boolean            @default(true)
  enrollments CourseEnrollment[]
  createdAt   DateTime           @default(now())
}

model CourseEnrollment {
  id              String        @id @default(cuid())
  sessionId       String
  session         CourseSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  name            String
  email           String
  phone           String?
  accreditation   String?       // "acreditat" | "neacreditat" | null
  paymentType     String        // "avans" | "integral"
  amountPaid      Int           // amount paid in bani
  totalPrice      Int           // total course price in bani
  paymentStatus   String        @default("pending") // "pending" | "paid" | "failed"
  stripeSessionId String?
  status          String        @default("pending") // "pending" | "confirmed" | "cancelled"
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ─── USERS & AUTH ──────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── ORDERS ────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  email           String
  name            String
  phone           String?
  address         String
  city            String
  county          String
  postalCode      String?
  paymentMethod   String      // "stripe" | "ramburs"
  paymentStatus   String      @default("pending") // "pending" | "paid" | "failed"
  stripeSessionId String?
  subtotal        Int         // bani
  discount        Int         @default(0) // discount in bani
  discountCode    String?
  shipping        Int         @default(0) // shipping in bani
  total           Int         // bani
  status          String      @default("pending") // "pending" | "processing" | "shipped" | "delivered" | "cancelled"
  // Invoicing (all optional — only set when the buyer ticks "vreau factură").
  // Persoană fizică: just needsInvoice + billingName/CNP optional. Persoană
  // juridică: billingCompany + billingVatId + billingRegNumber + billingAddress.
  needsInvoice     Boolean    @default(false)
  billingType      String?    // "person" | "company"
  billingName      String?    // name on invoice (may differ from shipping name)
  billingCnp       String?    // for persoană fizică, optional
  billingCompany   String?    // company name
  billingVatId     String?    // CUI
  billingRegNumber String?    // J…/…/… (Registrul Comerțului)
  billingAddress   String?    // billing address (street/city/county/postal as one line)
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  price     Int     // price at time of purchase, in bani
  quantity  Int
}

// ─── DISCOUNT CODES ────────────────────────────────────────

model DiscountCode {
  id            String    @id @default(cuid())
  code          String    @unique
  type          String    // "percentage" | "fixed"
  value         Int       // percentage (0-100) or fixed amount in bani
  minOrderValue Int?      // minimum order value in bani
  maxUses       Int?      // null = unlimited
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

// ─── EMAIL CAMPAIGNS ───────────────────────────────────────

model EmailCampaign {
  id          String   @id @default(cuid())
  name        String
  subject     String
  template    String   // "reengagement" | "new_products" | "course_promo" | "discount" | "custom"
  segment     String   // "all" | "orders" | "courses" | "registered"
  bodyHtml    String?  // custom body content (optional)
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  status      String   @default("draft") // "draft" | "sending" | "sent" | "failed"
  createdAt   DateTime @default(now())
  sentAt      DateTime?
}

// ─── SITE SETTINGS ─────────────────────────────────────────

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt
}
